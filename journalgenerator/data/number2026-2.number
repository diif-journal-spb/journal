                <word>мультиустойчивость</word>
                <word>подавление флаттера</word>
                <word>показатели Ляпунова</word>
                <word>разрывные системы</word>
                <word>скрытые колебания</word>
                <word>хаотические аттракторы</word>
            </keywords>
